o
\end_layout

\end_inset

C or 73.7
\begin_inset script superscript

\begin_layout Plain Layout
o
\end_layout

\end_inset

F,
 for Eastern Macedonia and Thrace is 20
\begin_inset script superscript

\begin_layout Plain Layout
o
\end_layout

\end_inset

C or 68.1
\begin_inset script superscript

\begin_layout Plain Layout
o
\end_layout

\end_inset

F,
 and for Crete is 20.17
\begin_inset script superscript

\begin_layout Plain Layout
o
\end_layout

\end_inset

C or 70.1
